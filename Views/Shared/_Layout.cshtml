@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MeetAmalfiCoast</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MeetAmalfiCoast.styles.css" asp-append-version="true" />
</head>

<body>
    <header class="site-header fixed-top">
        <nav class="navbar navbar-expand-lg navbar-dark">
            <div class="container-fluid px-lg-5">
                <a class="navbar-brand d-flex align-items-center" href="/" aria-label="Meet Amalfi Coast">
                    <img src="~/images/logo/logo.png" alt="Meet Amalfi Coast" class="brand-logo"
                         asp-append-version="true">
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false"
                        aria-label="Apri menu">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse justify-content-end" id="mainNavbar">
                    <ul class="navbar-nav align-items-lg-center gap-lg-4">
                        <li class="nav-item"><a
                            class="nav-link @(controller == "Home" && action == "Index" ? "active" : "")"
                            href="/">Home</a></li>
                            <li class="nav-item"><a
                                class="nav-link @(controller == "Home" && action == "Experiences" ? "active" : "")"
                                id="experiences-link" href="/#experiences">Experiences</a></li>
                                <li class="nav-item"><a
                                    class="nav-link @(controller == "Home" && action == "Destinations" ? "active" : "")"
                                    id="destinations-link" href="/#destinations">Destinations</a></li>
                                    <li class="nav-item"><a
                                        class="nav-link @(controller == "Home" && action == "About" ? "active" : "")"
                                        id="about-link" href="/#about">About us</a></li>
                                        <li class="nav-item"><a
                                            class="nav-link @(controller == "Home" && action == "Contact" ? "active" : "")"
                                            id="contact-link" href="/#contact">Contact</a></li>
                                            <li class="nav-item ms-lg-3"><a href="Planning" class="btn btn-gold">BOOK NOW</a>
                                            </li>
                                        </ul>
                                    </div>
                                </div>
                            </nav>
                        </header>
                        <div class="container">
                            <main role="main" class="pb-3">
                                @RenderBody()
                            </main>
                        </div>

                        @* <footer class="border-top footer text-muted"> *@
                        <footer class="site-footer footer">
                            <div class="container d-flex flex-column flex-lg-row justify-content-between align-items-center gap-3">
                                <p class="mb-0">© 2026 Meet Amalfi Coast. All rights reserved.</p>
                                <div class="footer-links">
                                    <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                                    <a asp-area="" asp-controller="Home" asp-action="Terms">Terms & Conditions</a>
                                </div>
                            </div>
                        </footer>
                        <script src="~/lib/jquery/dist/jquery.min.js"></script>
                        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
                        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
                        <script src="~/js/script.js" asp-append-version="true"></script>
                        <script src="~/js/utility.js"></script>
                        @await RenderSectionAsync("Scripts", required: false)

                        <div id="cookieBanner" class="cookie-banner d-none">
                            <div class="cookie-banner-content">

                                <div>
                                    <h5>We value your privacy</h5>

                                    <p>
                                        We use cookies to improve your browsing experience and analyze website traffic.
                                        By clicking <strong>Accept</strong>, you consent to the use of non-essential cookies.
                                    </p>

                                    <p class="cookie-links mb-0">
                                        Read our
                                        <a href="/Home/Privacy">Privacy Policy</a>,
                                        <a href="/Home/Terms">Terms &amp; Conditions</a>
                                        and
                                        <a href="/Home/Cookies">Cookie Policy</a>.
                                    </p>
                                </div>

                                <div class="cookie-banner-actions mt-3">
                                    <button type="button" id="rejectCookies" class="btn btn-outline-gold btn-sm">
                                        Reject
                                    </button>

                                    <button type="button" id="acceptCookies" class="btn btn-gold btn-sm">
                                        Accept
                                    </button>
                                </div>

                            </div>
                        </div>
                    </body>

                </html>