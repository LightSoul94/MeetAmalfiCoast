<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"] - MeetAmalfiCoast Pro</title>

    <link rel="icon" href="~/favicon.ico" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/styles.css" />
    <link rel="stylesheet" href="~/css/planning-layout.css" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css"
          rel="stylesheet">

</head>

<body class="planning-body">

    <header class="planning-header shadow-sm">

        <div class="container-fluid px-4">

            <div class="d-flex justify-content-between align-items-center">

                <a href="/" class="planning-logo">

                    <img src="~/images/logo/logo.png"
                         class="brand-logo-small"
                         alt="Meet Amalfi Coast">

                </a>

                <div class="planning-title">

                    <h5 class="mb-0">
                        MeetAmalfiCoast Pro Planning
                    </h5>

                </div>

                <div class="d-flex align-items-center gap-3">

                    <button class="btn btn-outline-gold">

                        <i class="bi bi-calendar-plus"></i>

                        New Booking

                    </button>

                    <button class="btn btn-gold">

                        <i class="bi bi-house"></i>

                        Website

                    </button>

                </div>

            </div>

        </div>

    </header>

    <main class="planning-main" style="background: black;">

        @RenderBody()

    </main>

    <footer class="border-top footer text-muted">
        <div class="container d-flex flex-column flex-lg-row justify-content-between align-items-center gap-3">
            <p class="mb-0">© 2026 Meet Amalfi Coast Pro. All rights reserved.</p>
            <div class="footer-links">
                <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                <a href="#">Terms & Conditions</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>