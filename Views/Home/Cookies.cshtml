@{
    ViewData["Title"] = "Cookie Policy";
    ViewData["Description"] = "Learn how Meet Amalfi Coasts uses cookies to improve your browsing experience and website functionality.";
}

<section class="py-5 legal-page">
    <div class="container" style="max-width:900px;">

        <div class="text-center mb-5">
            <span class="eyebrow">Legal</span>
            <h1>Cookie Policy</h1>
            <p class="text-muted">
                Last updated: @DateTime.UtcNow.ToString("MMMM dd, yyyy")
            </p>
        </div>

        <div class="mb-5">
            <h2>1. What Are Cookies</h2>

            <p>
                Cookies are small text files stored on your device when you visit a website.
                They help websites function properly, improve user experience and, where applicable,
                collect information about how visitors use the website.
            </p>
        </div>

        <div class="mb-5">
            <h2>2. How We Use Cookies</h2>

            <p>
                Meet Amalfi Coast may use cookies to ensure the correct functioning of the website,
                remember user preferences, improve website performance and analyze browsing activity.
            </p>
        </div>

        <div class="mb-5">
            <h2>3. Types of Cookies We Use</h2>

            <h3>Essential Cookies</h3>
            <p>
                These cookies are necessary for the website to work correctly and cannot be disabled
                through our cookie banner. They are usually set in response to actions such as page
                navigation, form submissions or privacy preference settings.
            </p>

            <h3>Analytics Cookies</h3>
            <p>
                These cookies help us understand how visitors interact with the website by collecting
                anonymous or aggregated information. They may be used only with your consent.
            </p>

            <h3>Third-Party Cookies</h3>
            <p>
                Some services integrated into the website, such as payment providers, maps, analytics
                tools or embedded content, may place cookies according to their own privacy and cookie
                policies.
            </p>
        </div>

        <div class="mb-5">
            <h2>4. Payment and Booking Services</h2>

            <p>
                When booking or payment features are used, third-party providers such as Stripe may
                process technical information necessary to complete the transaction securely.
                These providers may use cookies or similar technologies according to their own policies.
            </p>
        </div>

        <div class="mb-5">
            <h2>5. Managing Cookie Preferences</h2>

            <p>
                When you first visit this website, you may be asked to accept or reject non-essential
                cookies. You can change your preferences at any time by clearing your browser data
                or by using the cookie settings option available on the website, where provided.
            </p>
        </div>

        <div class="mb-5">
            <h2>6. Disabling Cookies from Your Browser</h2>

            <p>
                Most browsers allow you to manage, block or delete cookies through their settings.
                Please note that disabling essential cookies may affect the proper functioning of
                some parts of the website.
            </p>
        </div>

        <div class="mb-5">
            <h2>7. Updates to This Cookie Policy</h2>

            <p>
                We may update this Cookie Policy from time to time to reflect changes in technology,
                legal requirements or the services offered through the website.
            </p>
        </div>

        <div>
            <h2>8. Contact</h2>

            <p>
                If you have any questions about this Cookie Policy, you can contact us through the
                contact form available on this website.
            </p>
        </div>

    </div>
</section>