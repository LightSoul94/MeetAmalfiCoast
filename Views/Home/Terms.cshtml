@{
    ViewData["Title"] = "Terms & Conditions";
    ViewData["Description"] = "Read the Terms & Conditions governing bookings and services offered by Meet Amalfi Coasts.";
}

<section class="py-5 legal-page">
    <div class="container" style="max-width:900px;">

        <div class="text-center mb-5">
            <span class="eyebrow">Legal</span>
            <h1>Terms &amp; Conditions</h1>
            <p class="text-muted">
                Last updated: @DateTime.UtcNow.ToString("MMMM dd, yyyy")
            </p>
        </div>

        <div class="mb-5">
            <h2>1. Introduction</h2>

            <p>
                Welcome to Meet Amalfi Coast. By accessing this website or booking one of our
                services, you agree to be bound by these Terms &amp; Conditions.
                If you do not agree with any part of these terms, please do not use this website
                or our services.
            </p>
        </div>

        <div class="mb-5">
            <h2>2. Services</h2>

            <p>
                Meet Amalfi Coast provides private tours, transportation and personalized
                experiences throughout the Amalfi Coast and surrounding destinations.
                All services are subject to availability and confirmation.
            </p>
        </div>

        <div class="mb-5">
            <h2>3. Bookings</h2>

            <p>
                Customers may book available services directly through the website by selecting an available date and
                time.
            </p>

            <p>
                Bookings are subject to availability and become effective once the required deposit has been
                successfully processed and the booking confirmation has been issued.
            </p>

            <p>
                Customers are responsible for providing accurate contact information to ensure proper communication
                regarding their reservation.
            </p>
        </div>

        <div class="mb-5">
            <h2>4. Payments</h2>

            <p>
                Certain services require the payment of a deposit at the time of booking.
            </p>

            <p>
                Online payments are securely processed through Stripe. Meet Amalfi Coast does not collect or store
                payment card information.
            </p>

            <p>
                All prices are displayed in Euro (€), unless otherwise stated.
            </p>
        </div>

        <div class="mb-5">
            <h2>5. Booking Communications</h2>

            <p>
                After a booking has been completed, customers may receive service-related communications, including
                booking
                confirmations, appointment reminders and updates concerning their reservation.
            </p>

            <p>
                These communications are strictly related to the booked service and are not considered marketing
                communications.
            </p>
        </div>

        <div class="mb-5">
            <h2>6. Cancellation &amp; Refunds</h2>

            <p>
                Cancellation and refund eligibility depends on the type of service booked.
                Specific cancellation terms will be communicated during the booking process.
            </p>

            <p>
                Failure to attend a scheduled service without prior notice may result in the loss
                of any deposit or payment made.
            </p>
        </div>

        <div class="mb-5">
            <h2>7. Customer Responsibilities</h2>

            <p>
                Customers are expected to arrive on time, behave respectfully, and comply with
                all safety instructions provided during the experience.
            </p>

            <p>
                Customers are responsible for arriving at the agreed meeting point at the scheduled time.
                Late arrivals may result in delays or, where applicable, cancellation of the service without refund,
                according to the cancellation policy.
            </p>
        </div>

        <div class="mb-5">
            <h2>8. Changes to Services</h2>

            <p>
                Meet Amalfi Coast reserves the right to modify, postpone or cancel services due
                to weather conditions, safety concerns, force majeure or other circumstances
                beyond our reasonable control.
            </p>

            <p>
                Meet Amalfi Coast may contact the customer using the email address or telephone number provided during
                booking if changes to the reservation become necessary.
            </p>
        </div>

        <div class="mb-5">
            <h2>9. Limitation of Liability</h2>

            <p>
                To the maximum extent permitted by applicable law, Meet Amalfi Coast shall not be
                liable for indirect, incidental or consequential damages arising from the use of
                this website or participation in our services.
            </p>
        </div>

        <div class="mb-5">
            <h2>10. Intellectual Property</h2>

            <p>
                All content published on this website, including text, photographs, graphics,
                branding and logos, is protected by applicable intellectual property laws and may
                not be reproduced without prior written permission.
            </p>
        </div>

        <div class="mb-5">
            <h2>11. Privacy</h2>

            <p>
                Your personal information is processed in accordance with our Privacy Policy.
                We encourage you to review it before using our services.
            </p>
        </div>

        <div class="mb-5">
            <h2>12. Governing Law</h2>

            <p>
                These Terms &amp; Conditions shall be governed by and interpreted in accordance
                with the laws of Italy.
            </p>
        </div>

        <div>
            <h2>13. Contact</h2>

            <p>
                If you have any questions regarding these Terms &amp; Conditions, please contact
                us using the contact form available on this website.
            </p>
        </div>

    </div>
</section>