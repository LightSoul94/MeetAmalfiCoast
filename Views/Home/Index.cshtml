              <h3>Nancy Brilli</h3>
            </div>
          </article>
        </div>
        <div class="col-md-4">
          <article class="vip-card">
            <img src="~/images/vip/achille-lauro.jpg" asp-append-version="true" alt="Achille Lauro">
