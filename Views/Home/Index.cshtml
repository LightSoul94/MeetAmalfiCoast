@{
    ViewData["Title"] = "Private Driver & Tours on the Amalfi Coast";
    ViewData["Description"] = "Private transfers, airport pickups and unforgettable tours across the Amalfi Coast. Book your luxury experience with Meet Amalfi Coasts.";
}

@model MeetAmalfiCoast.Models.HomeViewModel

@section Scripts {
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
  <link rel="stylesheet" href="~/css/index.css" asp-append-version="true" />
}

<main id="home">
  <section class="hero-section hero-carousel">

    <div class="hero-slides">

      @for (int i = 0; i < Model.HeroMedia.Count; i++)
      {
        var file = Model.HeroMedia[i];
        var extension = System.IO.Path.GetExtension(file).ToLower();
        var activeClass = i == 0 ? "active" : "";

        <div class="hero-slide @activeClass">

          @if (extension == ".mp4")
          {
            <video muted playsinline preload="metadata">
              <source src="/images/hero/@file" type="video/mp4">
            </video>
          }
          else
          {
            <div class="hero-slide-image" style="background-image: url('/images/hero/@file');">
            </div>
          }

        </div>
      }

    </div>

    <div class="hero-overlay"></div>

    <div class="container-fluid px-lg-5 hero-content">
      <div class="row min-vh-100 align-items-center">
        <div class="col-lg-6 col-xl-5">

          <div class="hero-content-slides">

            <div class="hero-content-slide active">
              <p class="eyebrow">Private Transfer Service</p>

              <h1>
                Travel in Comfort,<br>
                Along the Amalfi Coast
              </h1>

              <div class="gold-separator my-4">
                <span></span>
              </div>

              <p class="hero-text">
                Private transfers from Naples, Amalfi, Positano, Ravello and Sorrento.
                Professional drivers, comfortable vehicles and journeys planned
                around your needs.
              </p>

              <a href="/Planning" class="btn btn-gold mt-4">
                Book your transfer
              </a>
            </div>

            <div class="hero-content-slide">
              <p class="eyebrow">People and experiences</p>

              <h1>
                More Than a Journey,<br>
                A Memory to Share
              </h1>

              <div class="gold-separator my-4">
                <span></span>
              </div>

              <p class="hero-text">
                Take a look at our photo gallery featuring our guests,
                their journeys and the memories we have shared along
                the Amalfi Coast.
              </p>

              <a asp-controller="Home" asp-action="Gallery" class="btn btn-gold mt-4">
                Explore the photo gallery
              </a>
            </div>

          </div>

        </div>
      </div>
    </div>

  </section>

  <section class="section-dark py-5">
    <div class="container py-lg-4">
      <div class="section-title text-center mb-5">
        <p class="eyebrow mb-2">We’ll take care of the travel, you gotta just enjoy the trip.</p>
      </div>

      <div class="row g-4 services-row">

        <div class="col-md-6 col-lg-3">
          <article class="services-card">
            <i class="fa-solid fa-car-side"></i>
            <h3>Luxury Vehicles</h3>
            <p>
              Travel in premium, comfortable vehicles carefully maintained
              to ensure a relaxing journey along the Amalfi Coast.
            </p>
          </article>
        </div>

        <div class="col-md-6 col-lg-3">
          <article class="services-card">
            <i class="fa-solid fa-route"></i>
            <h3>Door-to-Door Service</h3>
            <p>
              Private transfers from airports, train stations, hotels
              and ports directly to your destination.
            </p>
          </article>
        </div>

        <div class="col-md-6 col-lg-3">
          <article class="services-card">
            <i class="fa-solid fa-plane-arrival"></i>
            <h3>Flight Monitoring</h3>
            <p>
              We monitor your flight in real time to adapt your pickup,
              even in case of delays or early arrivals.
            </p>
          </article>
        </div>

        <div class="col-md-6 col-lg-3">
          <article class="services-card">
            <i class="fa-solid fa-map-location-dot"></i>
            <h3>Local Expert</h3>
            <p>
              Travel with someone who knows every road, every shortcut
              and the best routes across the Amalfi Coast.
            </p>
          </article>
        </div>

      </div>
    </div>
  </section>

  <section id="newsletter" class="section-dark py-5">
    <div class="container">
      <div class="newsletter-wrapper">

        <div class="gold-separator-large justify-content-center mb-5">
          <span></span>
        </div>

        <div class="section-title text-center">
          <p class="eyebrow mb-4">Join our newsletter</p>

          <p class="newsletter-text">
            Sign up to receive news, travel inspiration and exclusive
            promotions from Meet Amalfi Coast.
          </p>
        </div>

        <form id="newsletterForm" class="newsletter-form mt-5" novalidate>

          <div class="newsletter-input-group">
            <input id="newsletterEmail" name="newsletterEmail" type="email" class="form-control"
                   placeholder="Enter your email" autocomplete="email" maxlength="254" required>

            <button id="btnNewsletterSubscribe" type="submit" class="btn btn-gold">
              Sign Up
            </button>
          </div>

          <div class="form-check newsletter-privacy mt-3">
            <input id="newsletterPrivacy" class="form-check-input" type="checkbox" required>

            <label class="form-check-label" for="newsletterPrivacy">
              I have read the
              <a asp-controller="Home" asp-action="Privacy" target="_blank" rel="noopener noreferrer">
                Privacy Policy
              </a>
              and agree to receive promotional communications.
            </label>
          </div>

          <!-- Campo antispam invisibile agli utenti -->
          <div class="newsletter-honeypot" aria-hidden="true">
            <label for="newsletterWebsite">Website</label>
            <input id="newsletterWebsite" name="website" type="text" tabindex="-1" autocomplete="off">
          </div>

        </form>

        <div class="gold-separator-large justify-content-center mt-5">
          <span></span>
        </div>

      </div>
    </div>
  </section>

  <section id="experiences" class="split-section">
    <div class="container-fluid p-0">
      <div class="row g-0 align-items-stretch">

        <div class="col-lg-6 d-flex align-items-center">
          <div class="split-content">
            <h2>EXPERIENCE</h2>

            <div class="gold-separator my-4">
              <span></span>
            </div>

            <p>
              Meet Amalfi Coast transforms every journey into an elegant,
              personal and stress-free experience. From your very first inquiry
              to your final transfer, every detail is handled with care,
              professionalism and local expertise.
            </p>

            <div class="experience-signature mt-5">
              <img src="~/images/signatures/marco-signature.png" alt="Marco Signature" class="signature-image">

              <div class="signature-name">
                Marco Esposito
              </div>

              <div class="signature-role">
                Founder · Meet Amalfi Coast
              </div>
            </div>

          </div>
        </div>

        <div class="col-lg-6">
          <div class="split-image"></div>
        </div>

      </div>
    </div>
  </section>

