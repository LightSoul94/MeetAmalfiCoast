  <section id="destinations" class="destinations-section py-5">
    <div class="container-fluid px-0">

      <div class="section-title text-center mb-5">
        <p class="eyebrow mb-2">Our destinations</p>
        <div class="gold-separator justify-content-center">
          <span></span>
        </div>
      </div>

      <div class="destinations-slider-wrapper">

        <button type="button" class="destination-arrow destination-arrow-left" aria-label="Previous destinations">
          <i class="fa-solid fa-chevron-left"></i>
        </button>

        <div id="destinationsSlider" class="destinations-slider">

          <article class="destination-card destination-civitavecchia">
            <div class="destination-content">
              <p>Discover the historic port and its fascinating coastline.</p>
              <h3>Civitavecchia</h3>
              <a href="#contact">Explore</a>
            </div>
          </article>

          <article class="destination-card destination-firenze">
            <div class="destination-content">
              <p>Art, elegance and timeless Renaissance beauty.</p>
              <h3>Firenze</h3>
              <a href="#contact">Explore</a>
            </div>
          </article>

          <article class="destination-card destination-bari">
            <div class="destination-content">
              <p>Authentic streets, traditions and Mediterranean charm.</p>
              <h3>Bari</h3>
              <a href="#contact">Explore</a>
            </div>
          </article>

          <article class="destination-card destination-roma">
            <div class="destination-content">
              <p>History, culture and iconic monuments at every corner.</p>
              <h3>Roma</h3>
              <a href="#contact">Explore</a>
            </div>
          </article>

          <article class="destination-card destination-vietri">
            <div class="destination-content">
              <p>Colourful ceramics and the gateway to the Amalfi Coast.</p>
              <h3>Vietri sul Mare</h3>
              <a href="#contact">Explore</a>
            </div>
          </article>

          <article class="destination-card destination-praiano">
            <div class="destination-content">
              <p>Peaceful views, hidden beaches and authentic coastal life.</p>
              <h3>Praiano</h3>
              <a href="#contact">Explore</a>
            </div>
          </article>

          <article class="destination-card destination-amalfi">
            <div class="destination-content">
              <p>History, sea and the unmistakable heart of the coast.</p>
              <h3>Amalfi</h3>
              <a href="#contact">Explore</a>
            </div>
          </article>

          <article class="destination-card destination-positano">
            <div class="destination-content">
              <p>Vertical streets, elegant boutiques and breathtaking views.</p>
              <h3>Positano</h3>
              <a href="#contact">Explore</a>
            </div>
          </article>

          <article class="destination-card destination-sorrento">
            <div class="destination-content">
              <p>Panoramic terraces overlooking the Bay of Naples.</p>
              <h3>Sorrento</h3>
              <a href="#contact">Explore</a>
            </div>
          </article>

          <article class="destination-card destination-ravello">
            <div class="destination-content">
              <p>Gardens, music and unforgettable views from above.</p>
              <h3>Ravello</h3>
              <a href="#contact">Explore</a>
            </div>
          </article>

        </div>

        <button type="button" class="destination-arrow destination-arrow-right" aria-label="Next destinations">
          <i class="fa-solid fa-chevron-right"></i>
        </button>

      </div>

    </div>
  </section>

  <section id="luxury-trip" class="luxury-trip-section py-5">
    <div class="container py-lg-4">
      <div class="row align-items-center g-4">
        <div class="col-lg-5">
          <figure class="luxury-vehicle-card mb-0">
            <img src="~/images/hero/WhatsApp Image 2026-05-20 at 09.14.40 (4).jpeg" asp-append-version="true"
                 alt="Ford Tourneo Custom luxury minivan used for private transfers along the Amalfi Coast">
            <figcaption>Ford Tourneo Custom</figcaption>
          </figure>
        </div>
        <div class="col-lg-7">
          <div class="luxury-trip-content">
            <p class="eyebrow mb-2">Travel in comfort</p>
            <h2>Luxury trip</h2>
            <div class="gold-separator my-4"><span></span></div>
            <p>
              Enjoy your journey with a driver authorized by the Campania Region
              and a comfortable vehicle that travels the roads of the Amalfi Coast
              with complete calm and relaxation.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="driver-languages" class="languages-section py-5">
    <div class="container py-lg-4">
      <div class="section-title text-center mb-5">
        <p class="eyebrow mb-2">Clear communication throughout your journey</p>
        <h2>Driver languages</h2>
        <div class="gold-separator justify-content-center mt-4"><span></span></div>
      </div>
      <div class="row g-4 justify-content-center">
        <div class="col-6 col-md-3">
          <article class="language-card">
            <img src="~/images/languages/english.png" asp-append-version="true" alt="English flag">
            <h3>English</h3>
          </article>
        </div>
        <div class="col-6 col-md-3">
          <article class="language-card">
            <img src="~/images/languages/italian.png" asp-append-version="true" alt="Italian flag">
            <h3>Italian</h3>
          </article>
        </div>
        <div class="col-6 col-md-3">
          <article class="language-card">
            <img src="~/images/languages/spanish.png" asp-append-version="true" alt="Spanish flag">
            <h3>Spanish</h3>
          </article>
        </div>
        <div class="col-6 col-md-3">
          <article class="language-card">
            <img src="~/images/languages/portuguese.png" asp-append-version="true" alt="Portuguese flag">
            <h3>Portuguese</h3>
          </article>
        </div>
      </div>
    </div>
  </section>

  <section id="vip-guests" class="vip-section py-5">
    <div class="container py-lg-4">
      <div class="section-title text-center mb-5">
        <p class="eyebrow mb-2">Famous people we have had the honor of driving with</p>
        <h2>VIP with us</h2>
        <div class="gold-separator justify-content-center mt-4"><span></span></div>
      </div>
      <div class="row g-4">
        <div class="col-md-4">
          <article class="vip-card">
            <img src="~/images/vip/vincenzo-salemme.jpg" asp-append-version="true" alt="Vincenzo Salemme">
            <div class="vip-card-overlay">
